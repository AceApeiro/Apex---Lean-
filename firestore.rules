rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "info@acestool.com" && request.auth.token.email_verified == true));
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && request.auth.uid == userId;
      allow delete: if isAdmin();
    }

    match /folders/{folderId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /images/{imageId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /minutes/{minuteId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /messages/{messageId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /audit_logs/{logId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /blog_comments/{commentId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /blog_reactions/{reactionId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /blog_tasks/{taskId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /blog_posts/{postId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /blog_post_history/{historyId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /trophies/{trophyId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
